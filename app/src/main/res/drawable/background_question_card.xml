<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:bottom="204dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:centerColor="#FF30ABE8"
                android:endColor="#0049BAF2"
                android:startColor="#0049BAF2"
                android:type="linear" />
        </shape>
    </item>

    <item android:top="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#1A050C10" />
            <corners
                android:bottomLeftRadius="16dp"
                android:bottomRightRadius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0B0F14" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>