<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shape with gradient fill -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/disable"
                android:centerColor="@color/green"
                android:endColor="@color/red"
                android:angle="90" />
        </shape>
    </item>
    <!-- Inner shape to mask center, leaving 1dp border -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" /> <!-- Transparent center -->
        </shape>
    </item>
</layer-list>