<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:id="@android:id/background">
        <vector
            android:width="170dp"
            android:height="18dp"
            android:viewportWidth="300"
            android:viewportHeight="20">
            <path
                android:fillColor="@color/surface_high"
                android:pathData="M0,0 L300,0 L290,20 L10,20 Z"
                android:strokeWidth="1"
                android:strokeColor="@color/shade_quad" />
        </vector>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <vector
                android:width="170dp"
                android:height="18dp"
                android:viewportWidth="300"
                android:viewportHeight="20">
                <path
                    android:fillColor="@color/primary_variant"
                    android:pathData="M0,0 L300,0 L290,20 L10,20 Z" />
            </vector>
        </clip>
    </item>

</layer-list>