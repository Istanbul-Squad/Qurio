<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_result_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="-52dp"
            android:background="@drawable/card_result_data_background"
            android:paddingHorizontal="12dp"
            android:paddingTop="56dp"
            android:paddingBottom="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_great_job">

            <TextView
                android:id="@+id/text_reward"
                style="@style/Title.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reward"
                android:textColor="@color/shade_primary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/image_coins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="4dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/coins"
                android:paddingTop="6dp"
                android:scaleType="centerCrop"
                android:src="@drawable/im_coins"
                app:layout_constraintEnd_toStartOf="@id/text_number_of_coins"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_reward" />

            <!-- TODO: make number dynamic -->
            <TextView
                android:id="@+id/text_number_of_coins"
                style="@style/Title.Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/shade_primary"
                app:layout_constraintBottom_toBottomOf="@id/image_coins"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/image_coins"
                app:layout_constraintTop_toTopOf="@id/image_coins"
                tools:text="500" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_score_correct"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chamfered_shape"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                app:layout_constraintEnd_toStartOf="@id/card_score_incorrect"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/image_coins">

                <TextView
                    android:id="@+id/text_score_correct"
                    style="@style/Body.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/correct"
                    android:textColor="@color/shade_secondary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- TODO: make number dynamic -->
                <TextView
                    android:id="@+id/text_score_correct_value"
                    style="@style/Label.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text=""
                    android:textColor="@color/shade_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_score_correct"
                    tools:text="10" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_score_incorrect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/chamfered_shape"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                app:layout_constraintBottom_toBottomOf="@id/card_score_correct"
                app:layout_constraintEnd_toStartOf="@id/card_score_skipped"
                app:layout_constraintStart_toEndOf="@id/card_score_correct"
                app:layout_constraintTop_toTopOf="@id/card_score_correct">

                <TextView
                    android:id="@+id/text_score_incorrect"
                    style="@style/Body.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/incorrect"
                    android:textColor="@color/shade_secondary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- TODO: make number dynamic -->
                <TextView
                    android:id="@+id/text_score_incorrect_value"
                    style="@style/Label.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text=""
                    android:textColor="@color/shade_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_score_incorrect"
                    tools:text="2" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_score_skipped"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/chamfered_shape"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                app:layout_constraintBottom_toBottomOf="@id/card_score_correct"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/card_score_incorrect"
                app:layout_constraintTop_toTopOf="@id/card_score_correct">

                <TextView
                    android:id="@+id/text_score_skipped"
                    style="@style/Body.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text="@string/skipped"
                    android:textColor="@color/shade_secondary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- TODO: make number dynamic -->
                <TextView
                    android:id="@+id/text_score_skipped_value"
                    style="@style/Label.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="4dp"
                    android:text=""
                    android:textColor="@color/shade_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_score_skipped"
                    tools:text="0" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- TODO: make image and content description dynamic -->
        <ImageView
            android:id="@+id/image_great_job"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@string/great_job"
            android:scaleType="fitCenter"
            android:src="@drawable/im_great_job_3_star"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>