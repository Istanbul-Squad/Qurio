<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/surface_high">

    <include
        android:id="@+id/include_unlocked_character"
        layout="@layout/unlocked_character"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/include_locked_character"
        layout="@layout/locked_character"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ic_coin"
        android:layout_width="11dp"
        android:layout_height="12dp"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="4dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/ic_coin"
        android:src="@drawable/ic_coin_stack"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/character_name"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/price"
        style="@style/Label.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="4dp"
        android:text=""
        android:textColor="@color/shade_primary"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/character_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ic_coin"
        tools:text="4k" />

    <TextView
        android:id="@+id/character_name"
        style="@style/Label.Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingBottom="5dp"
        android:text=""
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/include_unlocked_character"
        tools:text="Rika"
        tools:textColor="@color/shade_secondary" />
</androidx.constraintlayout.widget.ConstraintLayout>
