<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include
            android:id="@+id/tobb_bar"
            layout="@layout/tob_bar"
            tools:layout="@layout/tob_bar" />

        <include
            android:id="@+id/statistics_component"
            layout="@layout/statistics_component"
            tools:layout="@layout/statistics_component"
             />

        <include
            android:id="@+id/streak_component"
            layout="@layout/streak_components"
            />

        <TextView
            android:id="@+id/header_games"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/games"
            style="@style/Title.Small"
            android:textColor="@color/shade_primary"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/header_games_see_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/all"
            android:drawableEnd="@drawable/im_arrow_right"
            android:drawablePadding="4dp"
            android:textColor="?attr/colorPrimary"
            style="@style/Label.Small"
            android:layout_gravity="end"
            android:layout_marginTop="0dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/category_game_horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:orientation="horizontal"
            tools:listitem="@layout/game_card" />

        <TextView
            android:id="@+id/header_last_game"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/last_games"
            style="@style/Title.Small"
            android:textColor="@color/shade_primary"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/all_last_game"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/all"
            android:drawableEnd="@drawable/im_arrow_right"
            android:drawablePadding="4dp"
            android:textColor="?attr/colorPrimary"
            style="@style/Label.Small"
            android:layout_gravity="end"
            android:layout_marginTop="0dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/last_game_Vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="16dp"
            tools:listitem="@layout/last_games" />

    </LinearLayout>
</ScrollView>
