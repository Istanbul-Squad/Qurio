<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/locked_character_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingTop="3dp"
    android:visibility="invisible">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/locked_character"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:paddingHorizontal="5dp"
        android:paddingTop="9dp"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CharacterCard"
        tools:src="@drawable/character_locked" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/blur_locked_character"
        android:layout_width="34dp"
        android:layout_height="35dp"
        android:layout_marginTop="9dp"
        android:background="@drawable/blur_background_character"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
       />

    <ImageView
        android:id="@+id/ic_lock"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:elevation="1dp"
        android:layout_marginHorizontal="5dp"
        android:contentDescription="@string/ic_locked"
        android:src="@drawable/ic_lock"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
