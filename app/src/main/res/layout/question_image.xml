<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_question_text"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/background_question_card"
        style="@style/background_card"
        android:layout_width="328dp"
        android:layout_height="205dp"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.utils.widget.ImageFilterView
        android:id="@+id/question_image"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="-24dp"
        android:elevation="1dp"
        android:src="@drawable/question_image"
        app:layout_constraintBottom_toBottomOf="@id/background_question_card"
        app:layout_constraintEnd_toEndOf="@id/background_question_card"
        app:layout_constraintStart_toStartOf="@id/background_question_card"
        app:layout_constraintTop_toTopOf="@id/header_question" />

    <TextView
        android:id="@+id/caption_Image"
        style="@style/Body.Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:elevation="1dp"
        android:text=""
        android:textColor="@color/shade_primary"
        app:layout_constraintBottom_toBottomOf="@id/background_question_card"
        app:layout_constraintEnd_toEndOf="@id/question_image"
        app:layout_constraintStart_toStartOf="@id/question_image"
        tools:text="The image caption"/>

    <ImageView
        android:id="@+id/header_question"
        android:layout_width="145dp"
        android:layout_height="40dp"
        android:layout_marginTop="-14dp"
        android:contentDescription="@string/header_question"
        android:elevation="1dp"
        android:src="@drawable/ic_header_question"
        app:layout_constraintEnd_toEndOf="@id/background_question_card"
        app:layout_constraintStart_toStartOf="@id/background_question_card"
        app:layout_constraintTop_toTopOf="@id/background_question_card" />

    <TextView
        android:id="@+id/number_of_question"
        style="@style/Title.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:elevation="1dp"
        android:text=""
        android:textColor="@color/shade_primary"
        app:layout_constraintEnd_toEndOf="@id/header_question"
        app:layout_constraintStart_toStartOf="@id/header_question"
        app:layout_constraintTop_toTopOf="@id/header_question"
        tools:text="Q 1/12"/>

</androidx.constraintlayout.widget.ConstraintLayout>
