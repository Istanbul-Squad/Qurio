<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="205dp">

    <ImageView
        android:id="@+id/background_question_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="13dp"
        android:contentDescription="@string/background_question_card"
        android:scaleType="fitXY"
        android:background="@drawable/background_question_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@+id/gradient_left"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@drawable/linear_gradiant"
        android:rotation="180"
        android:translationX="5dp"
        app:layout_constraintDimensionRatio="100:1"
        app:layout_constraintEnd_toStartOf="@id/header_question"
        app:layout_constraintTop_toTopOf="@id/background_question_card" />
    <View
        android:id="@+id/gradient_right"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@drawable/linear_gradiant"
        android:translationX="-5dp"
        app:layout_constraintDimensionRatio="100:1"
        app:layout_constraintStart_toEndOf="@id/header_question"
        app:layout_constraintTop_toTopOf="@id/background_question_card" />


    <ImageView
        android:id="@+id/header_question"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:contentDescription="@string/header_question"
        android:src="@drawable/ic_header_question"
        app:layout_constraintDimensionRatio="145:40"
        app:layout_constraintEnd_toEndOf="@id/background_question_card"
        app:layout_constraintStart_toStartOf="@id/background_question_card"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/numberOfQuestion"
        style="@style/Title.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/on_primary"
        app:layout_constraintBottom_toBottomOf="@+id/header_question"
        app:layout_constraintEnd_toEndOf="@id/header_question"
        app:layout_constraintStart_toStartOf="@id/header_question"
        app:layout_constraintTop_toTopOf="@id/header_question"
        tools:text="Q 1/12"/>

    <ImageView
        android:id="@+id/question_image"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="@style/questionImageStyle"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="8dp"
        android:scaleType="fitXY"
        android:contentDescription="@string/question_image"
        android:src="@drawable/question_image"
        app:layout_constraintEnd_toEndOf="@id/background_question_card"
        app:layout_constraintStart_toStartOf="@id/background_question_card"
        app:layout_constraintTop_toBottomOf="@+id/header_question" />

    <TextView
        android:id="@+id/caption_Image"
        style="@style/Body.Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="@color/shade_primary"
        app:layout_constraintEnd_toEndOf="@id/question_image"
        app:layout_constraintStart_toStartOf="@id/question_image"
        app:layout_constraintTop_toBottomOf="@+id/question_image"
        tools:text="The image caption"/>
</androidx.constraintlayout.widget.ConstraintLayout>