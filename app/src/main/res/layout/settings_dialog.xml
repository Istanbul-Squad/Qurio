<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="14dp"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/corner_shape"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/card_background"
        android:scaleType="fitXY"
        android:src="@drawable/dialog_border"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="320:260"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/gradient_left"
        android:layout_width="0dp"
        android:layout_height="1dp"
        app:layout_constraintDimensionRatio="56:1"
        android:background="@drawable/blue_linear_gradiant"
        android:rotation="180"
        android:translationX="5dp"
        app:layout_constraintEnd_toStartOf="@id/heptagon_shape"
        app:layout_constraintTop_toTopOf="@id/corner_shape" />

    <View
        android:id="@+id/gradient_right"
        android:layout_width="0dp"
        android:layout_height="1dp"
        app:layout_constraintDimensionRatio="56:1"
        android:background="@drawable/blue_linear_gradiant"
        android:translationX="-5dp"
        app:layout_constraintStart_toEndOf="@id/heptagon_shape"
        app:layout_constraintTop_toTopOf="@id/corner_shape" />

    <ImageView
        android:id="@+id/heptagon_shape"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginTop="-14dp"
        android:src="@drawable/heptagon_shape"
        app:layout_constraintDimensionRatio="145:40"
        app:layout_constraintEnd_toEndOf="@id/corner_shape"
        app:layout_constraintStart_toStartOf="@id/corner_shape"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/buy_life"
        style="@style/Title.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/on_primary"
        android:text="@string/settings"
        app:layout_constraintBottom_toBottomOf="@+id/heptagon_shape"
        app:layout_constraintEnd_toEndOf="@id/heptagon_shape"
        app:layout_constraintStart_toStartOf="@id/heptagon_shape"
        app:layout_constraintTop_toTopOf="@id/heptagon_shape"
        />

    <ImageView
        android:id="@+id/close_shape"
        android:layout_width="0dp"
        android:layout_height="26dp"
        android:src="@drawable/ic_close"
        app:layout_constraintDimensionRatio="22:26"
        app:layout_constraintEnd_toEndOf="@+id/corner_shape"
        app:layout_constraintTop_toTopOf="@+id/corner_shape" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_speaker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/heptagon_shape" />

    <TextView
        android:id="@+id/textView"
        style="@style/Body.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/sound"
        android:textColor="@color/shade_secondary"
        app:layout_constraintBottom_toBottomOf="@+id/imageView2"
        app:layout_constraintStart_toEndOf="@+id/imageView2"
        app:layout_constraintTop_toTopOf="@+id/imageView2" />

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="170dp"
        android:layout_height="28dp"
        android:layout_marginEnd="22dp"
        android:background="@drawable/slider_background"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/textView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/textView">

        <ImageView
            android:id="@+id/btnSoundMinus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/minus"
            android:gravity="center"
            android:src="@drawable/ic_minus"
            android:textColor="@color/primary" />

        <SeekBar
            android:id="@+id/customSoundSeekBar"
            android:layout_width="130dp"
            android:layout_height="28dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@drawable/seekbar_progress"
            android:thumb="@drawable/hexagon_shape"
            android:thumbOffset="40dp" />

        <ImageView
            android:id="@+id/btnSoundPlus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/minus"
            android:gravity="center"
            android:src="@drawable/ic_plus"
            android:textColor="@color/primary" />

    </LinearLayout>

    <ImageView
        android:id="@+id/music"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_music"
        android:layout_marginTop="26dp"
        app:layout_constraintEnd_toEndOf="@+id/imageView2"
        app:layout_constraintStart_toStartOf="@+id/imageView2"
        app:layout_constraintTop_toBottomOf="@+id/imageView2" />

    <TextView
        style="@style/Body.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/music"
        android:textColor="@color/shade_secondary"
        app:layout_constraintBottom_toBottomOf="@+id/music"
        app:layout_constraintEnd_toEndOf="@+id/textView"
        app:layout_constraintStart_toStartOf="@+id/textView"
        app:layout_constraintTop_toTopOf="@+id/music" />


    <LinearLayout
        android:layout_width="170dp"
        android:layout_height="28dp"
        android:background="@drawable/slider_background"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:layout_marginTop="26dp"
        app:layout_constraintEnd_toEndOf="@+id/linearLayout"
        app:layout_constraintStart_toStartOf="@+id/linearLayout"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout">

        <ImageView
            android:id="@+id/btn_music_minus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/minus"
            android:gravity="center"
            android:src="@drawable/ic_minus"
            android:textColor="@color/primary" />

        <SeekBar
            android:id="@+id/custom_music_seekbar"
            android:layout_width="130dp"
            android:layout_height="28dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@drawable/seekbar_progress"
            android:thumb="@drawable/hexagon_shape"
            android:thumbOffset="40dp" />

        <ImageView
            android:id="@+id/btn_music_plus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/minus"
            android:gravity="center"
            android:src="@drawable/ic_plus"
            android:textColor="@color/primary" />

    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_buy"
        style="@style/Label.Medium"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="2dp"
        android:background="@drawable/primary_button_background"
        android:text="@string/save_changes"
        android:layout_marginBottom="36dp"
        android:textAllCaps="false"
        android:textColor="@drawable/primary_button_text_color"
        app:layout_constraintBottom_toBottomOf="@+id/corner_shape"
        app:layout_constraintEnd_toStartOf="@+id/btn_cancel"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="@+id/corner_shape" />

    <ImageView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:contentDescription="@string/setting_icon"
        android:src="@drawable/ic_divder"
        android:layout_marginBottom="24dp"
        android:adjustViewBounds="true"
        app:layout_constraintBottom_toTopOf="@+id/btn_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_cancel"
        style="@style/Label.Medium"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/secondary_button_background"
        android:text="@string/discard"
        android:textAllCaps="false"
        android:textColor="@drawable/secondary_button_text_color"
        app:layout_constraintBottom_toBottomOf="@+id/btn_buy"
        app:layout_constraintEnd_toEndOf="@+id/corner_shape"
        app:layout_constraintStart_toEndOf="@+id/btn_buy"
        app:layout_constraintTop_toTopOf="@+id/btn_buy" />

</androidx.constraintlayout.widget.ConstraintLayout>