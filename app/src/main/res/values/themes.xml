<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->

    <style name="Theme.Qurio" parent="Base.Theme.Qurio" />

    <style name="Base.Theme.Qurio" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/shade_primary</item>
        <item name="colorSecondaryContainer">@color/orange_variant</item>

        <!-- Surface / Background -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/shade_secondary</item>
        <item name="android:colorBackground">@color/surface_high</item>

    </style>

    <!-- Splash screen theme -->

    <style name="Theme.Qurio.SplashScreen" parent="Theme.SplashScreen">
        <item name="postSplashScreenTheme">@style/Theme.Qurio</item>
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
    </style>


    <style name="HeadLine">
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="HeadLine.Large">
        <item name="android:textSize">28sp</item>
        <item name="lineHeight">42sp</item>
    </style>

    <style name="HeadLine.Medium">
        <item name="android:textSize">24sp</item>
        <item name="lineHeight">36sp</item>
    </style>

    <style name="HeadLine.Small">
        <item name="android:textSize">20sp</item>
        <item name="lineHeight">30sp</item>
    </style>


    <style name="Title">
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Title.Large">
        <item name="android:textSize">20sp</item>
        <item name="lineHeight">30sp</item>
    </style>

    <style name="Title.Medium">
        <item name="android:textSize">18sp</item>
        <item name="lineHeight">28sp</item>
    </style>

    <style name="Title.Small">
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
    </style>

    <style name="Body">
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>

    <style name="Body.Large">
        <item name="android:textSize">18sp</item>
        <item name="lineHeight">28sp</item>
    </style>

    <style name="Body.Medium">
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
    </style>

    <style name="Body.Small">
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">22sp</item>
    </style>

    <style name="Label">
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Label.Large">
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
    </style>

    <style name="Label.Medium">
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">22sp</item>
    </style>

    <style name="Label.Small">
        <item name="android:textSize">10sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:fontFamily">@font/fredoka_one_medium</item>
    </style>

    <style name="Label.XSmall">
        <item name="android:textSize">10sp</item>
        <item name="lineHeight">14sp</item>
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>


    <style name="DifficultyLevelStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="shapeAppearance">@style/DifficultyChipShape</item>
        <item name="chipStrokeWidth">0.5dp</item>
        <item name="chipStrokeColor">@color/shade_quad</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:layout_width">96dp</item>
        <item name="android:layout_height">37dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="textAllCaps">false</item>
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="android:textAlignment">center</item>
        <item name="chipBackgroundColor">@color/difficulty_chip_background</item>
        <item name="android:textColor">@color/difficulty_level_text_color</item>
    </style>

    <style name="DifficultyChipShape" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSizeTopLeft">8dp</item>
        <item name="cornerFamilyTopLeft">cut</item>
        <item name="cornerSizeBottomRight">8dp</item>
        <item name="cornerFamilyBottomRight">cut</item>
        <item name="cornerSizeBottomLeft">4dp</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerSizeTopRight">4dp</item>
        <item name="cornerFamilyTopRight">rounded</item>
    </style>

    <!-- Button Styles   -->
    <style name="Button">
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">22sp</item>
        <item name="android:textColor">@drawable/secondary_button_text_color</item>
    </style>

    <style name="Button.Primary" parent="Button">
        <item name="android:background">@drawable/primary_button_background</item>
        <item name="android:textColor">@drawable/primary_button_text_color</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="Button.Secondary" parent="Button">
        <item name="android:background">@drawable/secondary_button_background</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="Button.Text" parent="Button">
        <item name="android:background">#00000000</item>
    </style>


    <style name="CustomCardShape" parent="">
        <item name="cornerFamily">cut</item>
        <item name="cornerSizeTopRight">30dp</item>
        <item name="cornerSizeTopLeft">30dp</item>
        <item name="cornerSizeBottomRight">20dp</item>
        <item name="cornerSizeBottomLeft">20dp</item>
    </style>
</resources>
