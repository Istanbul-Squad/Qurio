<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Qurio" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_variant</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/shade_primary</item>
        <item name="colorSecondaryContainer">@color/orange_variant</item>

        <!-- Surface / Background -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/shade_secondary</item>
        <item name="android:colorBackground">@color/surface_high</item>

    </style>

    <style name="Theme.Qurio" parent="Base.Theme.Qurio" />

    <style name="HeadLine"/>
    <style name="HeadLine.Large">
        <item name="android:textSize">28sp</item>
        <item name="lineHeight">42sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="HeadLine.Medium">
        <item name="android:textSize">24sp</item>
        <item name="lineHeight">36sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="HeadLine.Small">
        <item name="android:textSize">20sp</item>
        <item name="lineHeight">30sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Title"/>
    <style name="Title.Large">
        <item name="android:textSize">20sp</item>
        <item name="lineHeight">30sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Title.Medium">
        <item name="android:textSize">18sp</item>
        <item name="lineHeight">28sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Title.Small">
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Body"/>
    <style name="Body.Large">
        <item name="android:textSize">18sp</item>
        <item name="lineHeight">28sp</item>
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>

    <style name="Body.Medium">
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>

    <style name="Body.Small">
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">22sp</item>
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>

    <style name="Label"/>
    <style name="Label.Large">
        <item name="android:textSize">16sp</item>
        <item name="lineHeight">24sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Label.Medium">
        <item name="android:textSize">14sp</item>
        <item name="lineHeight">22sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Label.Small">
        <item name="android:textSize">10sp</item>
        <item name="lineHeight">16sp</item>
        <item name="android:fontFamily">@font/fredoka_one_regular</item>
    </style>

    <style name="Label.XSmall">
        <item name="android:textSize">10sp</item>
        <item name="lineHeight">14sp</item>
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>
</resources>
